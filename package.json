{
  "name": "mychat",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @mychat/shared build",
    "build:server": "pnpm --filter @mychat/server build",
    "build:client": "pnpm --filter @mychat/client build",
    "dev": "pnpm --filter @mychat/test-app dev",
    "test": "pnpm -r run test",
    "lint": "eslint packages/*/src/**/*.{ts,tsx}"
  },
  "engines": {
    "node": ">=20"
  }
}
